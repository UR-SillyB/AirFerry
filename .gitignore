# Rust / Cargo
target/
**/*.rs.bk
*.pdb

# WebAssembly build artifacts
pkg/
*.wasm

# Node / pnpm
node_modules/
build/
.pnpm-store/
*.log
.DS_Store

# Build output / release artifacts (published as GitHub Release assets,
# never checked into git). See docs/build-browser.md.
dist/
# Standalone single-file web build output (apps/web/dist-standalone/).
dist-standalone/

# Plasmo extension build output + generated typings/cache (both repo-root and
# per-package). These are regenerable build artifacts, never source.
apps/sender/build/
apps/sender/.plasmo/
apps/sender/assets/icon.png
.plasmo/

# Android / Gradle
apps/scanner/.gradle/
apps/scanner/build/
apps/scanner/app/build/
apps/scanner/local.properties
apps/scanner/keystore.properties
apps/scanner/app/src/main/jniLibs/
apps/scanner/app/.cxx/
apps/scanner/captures/
*.apk
*.aab
*.keystore
!debug.keystore

# Windows / .NET (Rust C ABI DLL copied here by build-windows.ps1; C# build
# artifacts. transfer_engine.dll is a release artifact, never checked in.)
apps/windows/**/bin/
apps/windows/**/obj/
apps/windows/AirFerry.Windows/runtime/*.dll
apps/windows/.vs/

# IDE
.idea/
.vscode/
*.iml
*.swp

# OS
Thumbs.db
.DS_Store

# Published release artifacts (built via ./scripts/build-all.sh release;
# distributed through GitHub Releases, never checked into git).
release/

# CRX signing private key (do not commit)
*.pem

# Local agent working directories (session memory, scratch)
.workbuddy/
.zcode/
