<Page x:Class="AirFerry.Windows.Views.DeviceSelectView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AirFerry - 选择设备"
      Background="{StaticResource BgDark}"
      MinWidth="640" MinHeight="560">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar: title + settings. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="AirFerry"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" />
                <TextBlock Text="光学文件传输 · 选择视频设备"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Style="{StaticResource OutlinedButton}"
                    Content="⚙ 设置"
                    Click="Settings_Click"
                    VerticalAlignment="Top" />
        </Grid>

        <!-- Device list: webcams + capture cards together. -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBg}"
                CornerRadius="12"
                Padding="20"
                Margin="0,24,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="可用设备"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0,0,0,12" />
                <ListBox Grid.Row="1"
                         x:Name="DeviceList"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextPrimary}"
                         FontSize="15"
                         SelectionChanged="DeviceList_SelectionChanged" />
            </Grid>
        </Border>

        <!-- Selected device info / refresh. -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Style="{StaticResource OutlinedButton}"
                    Content="🔄 刷新设备列表"
                    Click="Refresh_Click" />
            <TextBlock x:Name="SelectedInfo"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13" />
        </StackPanel>

        <!-- Start scan button. -->
        <Button Grid.Row="3"
                Style="{StaticResource PrimaryButton}"
                Content="▶ 开始扫码"
                Click="StartScan_Click"
                Margin="0,16,0,0"
                IsEnabled="False"
                x:Name="StartButton" />
    </Grid>
</Page>
