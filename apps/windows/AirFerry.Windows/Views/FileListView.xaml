<Page x:Class="AirFerry.Windows.Views.FileListView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AirFerry - 已接收文件"
      Background="{StaticResource BgDark}"
      MinWidth="640" MinHeight="560">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource OutlinedButton}"
                    Content="‹ 返回" Click="Back_Click" />
            <TextBlock Grid.Column="1"
                       Text="已接收文件"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2" Style="{StaticResource OutlinedButton}"
                    Content="🗑 清空" Click="ClearAll_Click" x:Name="ClearButton" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource CardBg}"
                CornerRadius="12"
                Padding="8">
            <ListView x:Name="FilesListView"
                      Background="Transparent"
                      BorderThickness="0"
                      Foreground="{StaticResource TextPrimary}"
                      MouseDoubleClick="FileList_DoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="名称" Width="340"
                                        DisplayMemberBinding="{Binding DisplayName}" />
                        <GridViewColumn Header="大小" Width="100"
                                        DisplayMemberBinding="{Binding SizeText}" />
                        <GridViewColumn Header="修改时间" Width="160"
                                        DisplayMemberBinding="{Binding ModifiedText}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <TextBlock Grid.Row="2"
                   x:Name="PathHint"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Page>
