<Application x:Class="AirFerry.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/DeviceSelectView.xaml">
    <Application.Resources>
        <!-- Dark theme palette — mirrors Android's ScanActivity/SettingsActivity
             colors (BgDark #0F172A, CardBg #1E293B, Accent #3B82F6) so the two
             hosts look like the same app. -->
        <Color x:Key="BgDarkColor">#0F172A</Color>
        <Color x:Key="CardBgColor">#1E293B</Color>
        <Color x:Key="AccentColor">#3B82F6</Color>
        <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
        <Color x:Key="TextSecondaryColor">#94A3B8</Color>

        <SolidColorBrush x:Key="BgDark" Color="{StaticResource BgDarkColor}" />
        <SolidColorBrush x:Key="CardBg" Color="{StaticResource CardBgColor}" />
        <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
        <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="Divider" Color="#334155" />

        <!-- Shared button style: rounded, accent fill, primary text. -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2563EB" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1E40AF" />
                    <Setter Property="Opacity" Value="0.5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Outlined/secondary button: card bg + accent border. -->
        <Style x:Key="OutlinedButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#243449" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
