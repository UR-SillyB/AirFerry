<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Tests don't need WPF; target the plain net8.0 TFM so they can run on
         any OS (the CI host may be Linux/macOS and lack the Windows SDK). -->
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.9.0" />
    <PackageReference Include="xunit" Version="2.7.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.7" />
  </ItemGroup>

  <!-- The WPF app project targets net8.0-windows, which won't build on
       non-Windows hosts. Reference only the pure-C# sources (no WPF deps)
       by linking them in directly, so the tests verify the protocol math
       (IngestStatus bits, FrameHeader parsing, BundleParser) everywhere. -->
  <ItemGroup>
    <Compile Include="..\AirFerry.Windows\Scan\IngestStatus.cs" Link="Scan\IngestStatus.cs" />
    <Compile Include="..\AirFerry.Windows\Scan\FrameHeader.cs" Link="Scan\FrameHeader.cs" />
    <Compile Include="..\AirFerry.Windows\Scan\ReceiverSession.cs" Link="Scan\ReceiverSession.cs" />
    <Compile Include="..\AirFerry.Windows\Scan\ProgressSnapshot.cs" Link="Scan\ProgressSnapshot.cs" />
    <Compile Include="..\AirFerry.Windows\Bundle\BundleParser.cs" Link="Bundle\BundleParser.cs" />
    <Compile Include="..\AirFerry.Windows\Bundle\FileNameUtil.cs" Link="Bundle\FileNameUtil.cs" />
    <Compile Include="..\AirFerry.Windows\Native\NativeBridge.cs" Link="Native\NativeBridge.cs" />
  </ItemGroup>

</Project>
