<?xml version="1.0" encoding="utf-8"?>
<!--
    Full-backup rules (Android 6.0+). `allowBackup` is already `false` in the
    manifest, so this file is belt-and-suspenders: if a future change re-enables
    backup, the received/ cache (potentially sensitive files transferred over the
    air-gapped optical channel) and the cache/ dir must never leave the device.
-->
<full-backup-content>
    <exclude domain="file" path="received/" />
    <exclude domain="cache" path="." />
</full-backup-content>
