{
  "name": "@airferry/web",
  "version": "1.1.1",
  "description": "AirFerry web sender — static website that streams QR codes (reuses sender source).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "extract-lzma-wasm": "node scripts/extract-lzma-wasm.cjs",
